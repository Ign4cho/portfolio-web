---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta
      name="description"
      content="Ignacio Colomé - Desarrollador Web, QA Tester y analista de Business Intelligence. Construyo soluciones digitales con foco en calidad y datos."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />

    <link
      rel="preload"
      href="/fonts/montserrat-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <meta
      property="og:title"
      content="Ignacio Colomé | Desarrollador Web"
    />
    <meta
      property="og:description"
      content="Portfolio de Ignacio Colomé, Desarrollador Web con experiencia en QA Testing y Business Intelligence."
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:site_name"
      content="Portfolio de Ignacio Colomé"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Ignacio Colomé",
        "url": "https://github.com/Ign4cho",
        "sameAs": [
          "https://github.com/Ign4cho",
          "https://www.linkedin.com/in/ignacio-colome/"
        ],
        "jobTitle": "Desarrollador Web",
        "description": "Desarrollador Web con experiencia en QA Testing y Business Intelligence."
      }
    </script>
  </head>
  <body class="bg-[--background] sm:px-28 lg:px-20 px-9">
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Montserrat Variable";
    src: url("/fonts/montserrat-latin-wght-normal.woff2")
      format("woff2-variations");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --background: #101010;
    --sec: #a476ff;
    --white: #dfdfdf;
    --white-icon: #f3f3f398;
    --white-icon-tr: #f3f3f310;
  }

  * {
    font-family:
      "Montserrat Variable",
      -apple-system,
      system-ui,
      sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  *::selection {
    background-color: var(--sec);
    color: var(--background);
  }

  /* Scrollbar styles */

  ::-webkit-scrollbar {
    width: 15px;
  }

  ::-webkit-scrollbar-track {
    background: var(--container);
    border-radius: 30px;
  }

  ::-webkit-scrollbar-thumb {
    background: var(--background);
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--pink);
  }

  /* Scrollbar styles for Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: var(--line) var(--container);
  }
</style>
